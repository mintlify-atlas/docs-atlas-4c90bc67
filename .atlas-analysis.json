    "CColModel::AllocateData / RemoveCollisionVolumes",
    "CColStore::AddColSlot / LoadCol / RemoveCol / RequestCollision",
    "CColAccel::startCache / endCache / cacheLoadCol / addCacheCol",
    "CPhysical::ApplyMoveForce / ApplyTurnForce / ApplyForce",
    "CPhysical::CheckCollision / ApplyCollision / ApplySoftCollision",
    "CPhysical::ApplySpringCollision / ApplySpringDampening",
